# POS AI-First — Environment Variables

# Server
PORT=8080

# Database
DATABASE_PATH=./data/pos.db

# OpenRouter (NL→SQL)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini

# Session
SESSION_SECRET=change-this-to-a-random-string-32-chars

# Security
PIN_MAX_ATTEMPTS=5
PIN_LOCKOUT_MINUTES=5
QUERY_TIMEOUT_SECONDS=5
